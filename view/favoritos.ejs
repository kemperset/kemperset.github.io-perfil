<!DOCTYPE html>
<html lang="es">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Mis Favoritos</title>
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
  <link rel="stylesheet" href="/css/estilos.css">
</head>
<body>
  <!-- Navegación -->
  <nav class="navbar navbar-expand-lg navbar-dark bg-primary sticky-top">
    <div class="container-fluid">
      <a class="navbar-brand fw-bold" href="/">Mi Perfil Web</a>
      <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#navbarNav">
        <span class="navbar-toggler-icon"></span>
      </button>
      <div class="collapse navbar-collapse" id="navbarNav">
        <ul class="navbar-nav ms-auto">
          <li class="nav-item">
            <a class="nav-link" href="/">Inicio</a>
          </li>
          <li class="nav-item">
            <a class="nav-link" href="/perfil">Perfil</a>
          </li>
          <li class="nav-item">
            <a class="nav-link" href="/album">Álbum</a>
          </li>
          <li class="nav-item">
            <a class="nav-link" href="/contactos">Contactos</a>
          </li>
          <li class="nav-item">
            <a class="nav-link active" href="/favoritos">
              Favoritos <span class="badge bg-success" id="favoritosCount">0</span>
            </a>
          </li>
        </ul>
      </div>
    </div>
  </nav>

  <!-- Contenido Principal -->
  <div class="container mt-5">
    <h1 class="mb-5 text-center">⭐ Mis Favoritos</h1>

    <!-- Tabs para favoritos -->
    <ul class="nav nav-tabs mb-4" role="tablist">
      <li class="nav-item" role="presentation">
        <button class="nav-link active" id="contactos-fav-tab" data-bs-toggle="tab" data-bs-target="#contactos-fav" type="button" role="tab">
          📞 Contactos Favoritos
        </button>
      </li>
      <li class="nav-item" role="presentation">
        <button class="nav-link" id="fotos-fav-tab" data-bs-toggle="tab" data-bs-target="#fotos-fav" type="button" role="tab">
          📸 Fotos Guardadas
        </button>
      </li>
    </ul>

    <!-- Contenido de tabs -->
    <div class="tab-content">
      <!-- Tab de Contactos Favoritos -->
      <div class="tab-pane fade show active" id="contactos-fav" role="tabpanel">
        <div id="contactosFavoritosContainer">
          <!-- Se cargará con AJAX -->
        </div>
        <div id="sinContactosFav" class="alert alert-info text-center" style="display: none;">
          <p class="mb-0">No tienes contactos en favoritos. <a href="/contactos">Agrega algunos</a></p>
        </div>
      </div>

      <!-- Tab de Fotos Guardadas -->
      <div class="tab-pane fade" id="fotos-fav" role="tabpanel">
        <div id="fotosGuardasContainer">
          <!-- Se cargará con AJAX -->
        </div>
        <div id="sinFotosGuardadas" class="alert alert-info text-center" style="display: none;">
          <p class="mb-0">No tienes fotos guardadas. <a href="/album">Guarda tus fotos favoritas</a></p>
        </div>
      </div>
    </div>

    <!-- Resumen de Favoritos -->
    <div class="row mt-5">
      <div class="col-lg-8 mx-auto">
        <div class="card border-0 shadow-lg bg-light">
          <div class="card-body text-center">
            <h5 class="card-title">Resumen de Favoritos</h5>
            <div class="row mt-4">
              <div class="col-6">
                <p class="fs-5 fw-bold text-primary" id="countContactosFav">0</p>
                <p class="text-muted">Contactos</p>
              </div>
              <div class="col-6">
                <p class="fs-5 fw-bold text-success" id="countFotosGuardadas">0</p>
                <p class="text-muted">Fotos</p>
              </div>
            </div>
          </div>
        </div>
      </div>
    </div>

    <!-- Información -->
    <div class="row mt-5">
      <div class="col-12">
        <div class="alert alert-info" role="alert">
          <strong>💡 Información:</strong> Tus favoritos se guardan en la sesión actual. 
          Puedes agregar contactos desde la sección de <a href="/contactos" class="alert-link">Contactos</a> 
          y fotos desde la sección de <a href="/album" class="alert-link">Álbum</a>.
        </div>
      </div>
    </div>
  </div>

  <!-- Footer -->
  <footer class="bg-dark text-white text-center py-4 mt-5">
    <p>&copy; 2025 Mi Aplicación de Perfil. Todos los derechos reservados.</p>
  </footer>

  <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
  <script src="/js/script.js"></script>
</body>
</html>
