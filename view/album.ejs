<!DOCTYPE html>
<html lang="es">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Álbumes de Fotos</title>
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
  <link rel="stylesheet" href="/css/estilos.css">
</head>
<body>
  <!-- Navegación -->
  <nav class="navbar navbar-expand-lg navbar-dark bg-primary sticky-top">
    <div class="container-fluid">
      <a class="navbar-brand fw-bold" href="/">Mi Perfil Web</a>
      <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#navbarNav">
        <span class="navbar-toggler-icon"></span>
      </button>
      <div class="collapse navbar-collapse" id="navbarNav">
        <ul class="navbar-nav ms-auto">
          <li class="nav-item">
            <a class="nav-link" href="/">Inicio</a>
          </li>
          <li class="nav-item">
            <a class="nav-link" href="/perfil">Perfil</a>
          </li>
          <li class="nav-item">
            <a class="nav-link active" href="/album">Álbum</a>
          </li>
          <li class="nav-item">
            <a class="nav-link" href="/contactos">Contactos</a>
          </li>
          <li class="nav-item">
            <a class="nav-link" href="/favoritos">
              Favoritos <span class="badge bg-success" id="favoritosCount">0</span>
            </a>
          </li>
        </ul>
      </div>
    </div>
  </nav>

  <!-- Contenido Principal -->
  <div class="container mt-5">
    <h1 class="mb-5 text-center">📸 Mis Álbumes de Fotos</h1>

    <!-- Tabs para los álbumes -->
    <ul class="nav nav-tabs mb-4" role="tablist">
      <% datos.albumes.forEach((album, index) => { %>
        <li class="nav-item" role="presentation">
          <button class="nav-link <%= index === 0 ? 'active' : '' %>" id="album-<%= album.id %>-tab" data-bs-toggle="tab" data-bs-target="#album-<%= album.id %>" type="button" role="tab">
            <%= album.nombre %>
          </button>
        </li>
      <% }); %>
    </ul>

    <!-- Contenido de los tabs -->
    <div class="tab-content">
      <% datos.albumes.forEach((album, index) => { %>
        <div class="tab-pane fade <%= index === 0 ? 'show active' : '' %>" id="album-<%= album.id %>" role="tabpanel">
          <!-- Header del álbum -->
          <div class="row mb-5">
            <div class="col-12">
              <div class="card border-0 shadow-sm mb-4">
                <div class="card-body">
                  <h3 class="card-title"><%= album.nombre %></h3>
                  <p class="card-text lead"><%= album.descripcion %></p>
                  <p class="text-muted">📷 <%= album.fotos.length %> fotos en este álbum</p>
                </div>
              </div>
            </div>
          </div>

          <!-- Grid de fotos -->
          <div class="row" id="album-<%= album.id %>-fotos">
            <% album.fotos.forEach(foto => { %>
              <div class="col-md-4 mb-4">
                <div class="card shadow-lg hover-card position-relative foto-card" data-foto-id="<%= foto.id %>">
                  <img src="<%= foto.url %>" class="card-img-top" alt="<%= foto.titulo %>" style="height: 300px; object-fit: cover;">
                  
                  <!-- Overlay con información -->
                  <div class="card-overlay">
                    <div class="overlay-content">
                      <h5 class="text-white"><%= foto.titulo %></h5>
                    </div>
                  </div>

                  <div class="card-body">
                    <p class="card-text mb-3"><%= foto.titulo %></p>
                    <div class="d-flex justify-content-between align-items-center">
                      <button class="btn btn-sm btn-outline-danger like-btn" data-foto-id="<%= foto.id %>">
                        ❤️ <span class="like-count"><%= foto.likes %></span>
                      </button>
                      <button class="btn btn-sm btn-outline-warning favorito-btn" data-foto-id="<%= foto.id %>" data-titulo="<%= foto.titulo %>">
                        ⭐ Guardar
                      </button>
                    </div>
                  </div>
                </div>
              </div>
            <% }); %>
          </div>
        </div>
      <% }); %>
    </div>

    <!-- Resumen de álbumes -->
    <hr class="my-5">
    <div class="row mt-5">
      <div class="col-12">
        <h3 class="mb-4">Resumen de Álbumes</h3>
      </div>
      <% datos.albumes.forEach(album => { %>
        <div class="col-md-4 mb-4">
          <div class="card border-0 shadow-sm">
            <img src="<%= album.fotos[0].url %>" class="card-img-top" alt="<%= album.nombre %>" style="height: 200px; object-fit: cover;">
            <div class="card-body">
              <h5 class="card-title"><%= album.nombre %></h5>
              <p class="card-text text-muted"><%= album.descripcion %></p>
              <p class="mb-3"><small class="text-muted">📷 <%= album.fotos.length %> fotos</small></p>
              <a href="#album-<%= album.id %>-tab" class="btn btn-primary btn-sm" data-bs-toggle="tab" data-bs-target="#album-<%= album.id %>">
                Ver Álbum
              </a>
            </div>
          </div>
        </div>
      <% }); %>
    </div>

    <!-- Estadísticas generales -->
    <div class="row mt-5">
      <div class="col-lg-8 mx-auto">
        <div class="card border-0 shadow-lg bg-light">
          <div class="card-body text-center">
            <h5 class="card-title">Estadísticas de tus Fotos</h5>
            <div class="row mt-4">
              <div class="col-4">
                <p class="fs-5 fw-bold text-primary"><%= datos.albumes.length %></p>
                <p class="text-muted">Álbumes</p>
              </div>
              <div class="col-4">
                <p class="fs-5 fw-bold text-success"><%= datos.albumes.reduce((total, album) => total + album.fotos.length, 0) %></p>
                <p class="text-muted">Fotos Totales</p>
              </div>
              <div class="col-4">
                <p class="fs-5 fw-bold text-danger" id="totalLikes"><%= datos.albumes.reduce((total, album) => total + album.fotos.reduce((t, f) => t + f.likes, 0), 0) %></p>
                <p class="text-muted">Me Gusta Totales</p>
              </div>
            </div>
          </div>
        </div>
      </div>
    </div>
  </div>

  <!-- Footer -->
  <footer class="bg-dark text-white text-center py-4 mt-5">
    <p>&copy; 2025 Mi Aplicación de Perfil. Todos los derechos reservados.</p>
  </footer>

  <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
  <script src="/js/script.js"></script>
</body>
</html>
